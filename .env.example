# Copy to .env and fill in. All variables are prefixed ISHLD_ (see config.py).
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- required in production ---
ISHLD_ENVIRONMENT=dev                 # set to "production" to enforce hardening
ISHLD_SECRET_KEY=                     # REQUIRED in production; random per-process if unset in dev
ISHLD_ALLOWED_HOSTS=localhost,127.0.0.1
ISHLD_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- storage ---
ISHLD_DATABASE_URL=sqlite:///./imposter_shield.db
# Postgres: postgresql+psycopg2://shield:PASSWORD@db:5432/imposter_shield

# --- async worker (Celery / Redis) ---
ISHLD_CELERY_BROKER_URL=redis://localhost:6379/0
ISHLD_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- docker-compose only ---
POSTGRES_PASSWORD=                    # REQUIRED by docker-compose

# --- optional external services ---
ISHLD_SERPAPI_KEY=
ISHLD_VT_API_KEY=

# --- optional tuning ---
ISHLD_REVIEW_THRESHOLD=0.90
ISHLD_IMAGE_MAX_BYTES=26214400
ISHLD_ALLOW_PRIVATE_NETWORK_URLS=false
# ISHLD_ADMIN_PASSWORD=               # if set, seed.py uses it and won't echo it
